TZ=Asia/Jakarta

# Port publik aplikasi harus mengarah ke frontend/UI, bukan backend API.
APP_PORT=3004

# Database lama / external
DB_HOST=IP-ATAU-HOST-DB-LAMA
DB_PORT=3306
DB_NAME=sisdmk2
DB_USER=pegawai
DB_PASS=ganti-password-db

# Opsional: hanya dipakai bila Anda menyalakan profile internal-db
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=ganti-root-password

# App ports
BACKEND_PORT=3000
FRONTEND_PORT=3004

# JWT / API
JWT_SECRET=ganti-jwt-secret-yang-kuat
API_URL=http://IP-ATAU-DOMAIN-API:3000/api

# Penting: ini dibaca browser/frontend saat build
# Isi dengan URL backend yang bisa diakses user/browser
NEXT_PUBLIC_API_URL=http://IP-ATAU-DOMAIN-API:3000/api
